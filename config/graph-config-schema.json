{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "description": "",
    "type": "object",
    "properties": {
        "credentials": {
            "type": "object",
            "properties": {
                "host": {
                    "type": "string",
                    "minLength": 1
                },
                "username": {
                    "type": "string",
                    "minLength": 1
                },
                "password": {
                    "type": "string",
                    "minLength": 1
                },
                "database": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "required": [
                "host",
                "username",
                "password",
                "database"
            ]
        },
        "graphs": {
            "type": "array",
            "uniqueItems": true,
            "minItems": 1,
            "items": {
                "required": [
                    "name",
                    "relations"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "relations": {
                        "       type": "array",
                        "uniqueItems": true,
                        "minItems": 1,
                        "items": {
                            "required": [
                                "edge_collection",
                                "from_vertex_collections",
                                "to_vertex_collections"
                            ],
                            "properties": {
                                "edge_collection": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "from_vertex_collections": {
                                    "type": "array"
                                },
                                "to_vertex_collections": {
                                    "type": "array"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "required": [
        "credentials",
        "graphs"
    ]
}
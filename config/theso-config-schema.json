{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "description": "Configuration of the openTheso to arangoDB Python tool",
    "type": "object",
    "properties": {
        "credentials": {
            "type": "object",
            "properties": {
                "host": {
                    "type": "string",
                    "minLength": 1
                },
                "username": {
                    "type": "string",
                    "minLength": 1
                },
                "password": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "required": [
                "host",
                "username",
                "password",
                "database"
            ]
        },
        "thesauri": {
            "type": "array",
            "description": "List of thesaurus specific config",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "source",
                    "type"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the collection in wich to put the thesaurus (The edges collection will just have '_EDGES' appended to this string)"
                    },
                    "source": {
                        "type": "string",
                        "description": "The API link to the thesaurus"
                    },
                    "type": {
                        "enum": ["raw", "graph"]
                    }
                }
            }
        }
    },
    "required": [
        "credentials",
        "thesauri"
    ]
}